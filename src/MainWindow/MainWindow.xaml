<!--
    This is the main window of the Tingen Transmorger application. I am not a UI designer, so it probably breaks a
    number of UI best practices, but I did my best! To that point, this window has a resolution of 1200x700, and is not
    designed to be resized.
    
    I've provided detailed comments throughout the XAML to explain the structure and purpose of each element in the UI,
    and the code-behind contains is written to be as clear as possible.
-->

<Window
    x:Class="TingenTransmorger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TingenTransmorger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tingen Transmorger"
    Width="1200"
    Height="700"
    ResizeMode="NoResize"
    mc:Ignorable="d">

    <!-- MainWindow grid -->
    <Grid x:Name="grdMainWindow"
        Width="1200"
        HorizontalAlignment="Right">

        <!--
            MainWindow border
            Contains all of the UI components of the main window.
            The background color of this border changes depending on the mode Tingen Transmorger is in.
        -->
        <Border x:Name="brdrMainWindow"
            Width="1180"
            Margin="10,10,0,10"
            HorizontalAlignment="Left"
            Background="SteelBlue">
            <Border.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10" />
                </Style>
            </Border.Resources>

            <!--
                MainWindow grid column definitions
                Left column: Components related to searching for patients/providers
                Right column: Components related to patient/provider/meetings details.
            -->
            <Grid x:Name="gridMainWindowColumnsDefinition">
                <Grid.ColumnDefinitions>
                    <!-- Left column definition -->
                    <ColumnDefinition x:Name="colMainWindowLeftColumnDefinition"
                        Width="340" />
                    <!-- Right column definition -->
                    <ColumnDefinition x:Name="colMainWindowRightColumnDefinition"
                        Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left column border -->
                <Border x:Name="brdrLeftColumn"
                    Grid.Column="0"
                    Margin="12,12,4,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="6,0,0,6">

                    <!--
                        Search panel
                        Contains all of the components related to searching for patients/providers, viewing the results,
                        and some space at the bottom for additional information.
                    -->
                    <StackPanel x:Name="spnlSearch"
                        Orientation="Vertical">

                        <!--
                            Search options panel
                            Contains the search toggle button, and the search by name/ID radio buttons.
                        -->
                        <StackPanel x:Name="spnlSearchOptions"
                            Grid.Column="0"
                            Background="White"
                            Orientation="Horizontal">

                            <!--
                                Search toggle button
                                When this button is clicked, it toggles between patient and provider search modes, and
                                the content of the button is updated accordingly.
                            -->
                            <Button x:Name="btnSearchToggle"
                                Width="200"
                                Height="42"
                                Margin="10,10,0,8"
                                HorizontalAlignment="left"
                                Click="btnSearchToggle_Clicked"
                                Content="Patient Search"
                                FontSize="18"
                                FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Search by name/ID buttons -->
                            <StackPanel x:Name="spnlSearchByNameOrIdComponents"
                                Orientation="Vertical">

                                <!-- Search by name button -->
                                <RadioButton x:Name="rbtnSearchByName"
                                    Width="116"
                                    Margin="5,12,0,0"
                                    VerticalContentAlignment="Center"
                                    Checked="rbtnSearchBy_Checked"
                                    Content="By name"
                                    FontSize="14" />

                                <!-- Search by ID button -->
                                <RadioButton x:Name="rbtnSearchById"
                                    Width="116"
                                    Margin="5,5,0,0"
                                    VerticalContentAlignment="Center"
                                    Checked="rbtnSearchBy_Checked"
                                    Content="By ID"
                                    FontSize="14" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Search box -->
                        <StackPanel x:Name="spnlSearchBox"
                            Margin="0,0,0,6"
                            Orientation="Horizontal">

                            <!-- Search box -->
                            <TextBox x:Name="txbxSearchBox"
                                Width="290"
                                Height="32"
                                Margin="10,0,8,0"
                                Padding="10,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                TextChanged="txbxSearch_TextChanged">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <!-- Search result list -->
                        <ListBox x:Name="lstbxSearchResults"
                            Height="476"
                            SelectionChanged="lstbxSearchResults_SelectionChanged">
                            <ListBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="7" />
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </StackPanel>

                    <!-- This space is reserved for future use and additional information. -->

                </Border>

                <!-- Right column border -->
                <Border x:Name="brdrRightColumn"
                    Grid.Column="1"
                    Margin="4,12,12,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="0,6,6,0">

                    <!--
                        Details panel
                        Contains all of the components related to patient/provider/meetings details.
                    -->
                    <StackPanel x:Name="spnlDetail">

                        <!--
                            User detail panel
                            Contains the patient/provider name and ID.
                            Contains the patient phone and email information.
                        -->
                        <StackPanel x:Name="spnlUserDetail"
                            Height="65"
                            Margin="0"
                            Background="White"
                            Orientation="Horizontal">

                            <!--
                                User type label
                                The UserType is either "PATIENT" or "PROVIDER", depending on the search mode
                                This label will either say "PATIENT" or "PROVIDER", depending on the search mode.
                            -->
                            <Label x:Name="lblUserTypeKey"
                                Width="100"
                                Height="64"
                                Margin="0,-1,0,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Black"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="PATIENT"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="White">
                                <Label.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5,0,0,5" />
                                    </Style>
                                </Label.Resources>
                            </Label>

                            <!-- User name and ID panel -->
                            <StackPanel x:Name="spnlUserNameAndId"
                                Orientation="vertical">

                                <!-- User Name -->
                                <Label x:Name="lblUserNameValue"
                                    Width="280"
                                    Height="32"
                                    Margin="0,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    BorderBrush="Black"
                                    BorderThickness="1,1,1,0"
                                    Content="----------------------------------"
                                    FontSize="16"
                                    FontWeight="SemiBold">
                                    <Label.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,5,0,0" />
                                        </Style>
                                    </Label.Resources>
                                </Label>

                                <!-- User ID -->
                                <Label x:Name="lblUserIdValue"
                                    Width="280"
                                    Height="32"
                                    Margin="0,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1,0,1,1"
                                    Content="---------------------------------------"
                                    FontSize="14"
                                    FontWeight="Regular"
                                    Foreground="Black">
                                    <Label.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,0,5,0" />
                                        </Style>
                                    </Label.Resources>
                                </Label>
                            </StackPanel>

                            <!--
                                User contacts panel
                                Shows any phone/email details for the user.
                                Currently this is only visible in patient search mode, but I'm naming it "User" in case
                                I want to add provider contact information in the future.
                            -->
                            <StackPanel x:Name="spnlUserContacts"
                                Orientation="Vertical">

                                <!-- User phone panel -->
                                <StackPanel x:Name="spnlUserPhone"
                                    Orientation="Horizontal">

                                    <!-- User phone label -->
                                    <Label x:Name="lblUserPhoneKey"
                                        Width="60"
                                        Height="30"
                                        Margin="5,0,0,4"
                                        HorizontalContentAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        Background="Black"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        Content="Phone"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5,0,0,5" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>

                                    <!-- User phone number -->
                                    <Label x:Name="lblUserPhoneValue"
                                        Width="325"
                                        Height="30"
                                        Margin="0,0,0,4"
                                        Padding="0,0,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="Black"
                                        BorderThickness="1,1,0,1"
                                        Content="------------------------------------------------"
                                        FontSize="16"
                                        FontWeight="SemiBold">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,0" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>

                                    <!-- User phone detail button -->
                                    <Button x:Name="btnUserPhoneDetail"
                                        Width="32"
                                        Height="30"
                                        Margin="0,0,0,4"
                                        Click="btnUserPhoneDetail_Clicked">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,5,5,0" />
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <!-- User email panel -->
                                <StackPanel x:Name="spnlUserEmail"
                                    Orientation="Horizontal">

                                    <!-- User email label -->
                                    <Label x:Name="lblUserEmailKey"
                                        Width="60"
                                        Height="30"
                                        Margin="5,0,0,0"
                                        HorizontalContentAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        Background="Black"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        Content="Email"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5,0,0,5" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>

                                    <!-- User email value -->
                                    <Label x:Name="lblUserEmailValue"
                                        Width="325"
                                        Height="30"
                                        Margin="0,0,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="Black"
                                        BorderThickness="1,1,0,1"
                                        Content="----------------------------------------------------------------"
                                        FontSize="12"
                                        FontWeight="Regular">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,0" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>

                                    <!-- User email detail button -->
                                    <Button x:Name="btnUserEmailDetail"
                                        Width="32"
                                        Height="30"
                                        Margin="0,0,0,0"
                                        Click="btnUserEmailDetail_Clicked">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,5,5,0" />
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!--
                            Meeting detail panel
                            Contains all of the meeting detail components, including the meeting breakdown, the meeting
                            list, and the three sections of meeting details information.
                        -->
                        <StackPanel x:Name="spnlMeetingResult"
                            Margin="0,10,0,0">

                            <!--
                                Meetings breakdown panel
                                Displays a breakdown of the meetings for the selected user.
                            -->
                            <StackPanel x:Name="spnlMeetingBreakdown"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">

                                <!-- Total meetings textbox -->
                                <TextBlock x:Name="txbkTotalMeetingsValue"
                                    Margin="0,0,5,0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Meetings" />

                                <!-- Separator -->
                                <TextBlock x:Name="txbkMeetingsSeparator0"
                                    FontSize="16"
                                    Text="- " />

                                <!-- Completed meetings textbox -->
                                <TextBlock x:Name="txbkCompletedMeetingsValue"
                                    FontSize="16"
                                    Foreground="Green"
                                    Text="0 Completed" />

                                <!-- Separator -->
                                <TextBlock x:Name="txbkMeetingsSeparator1"
                                    FontSize="16"
                                    Text=" / " />

                                <!-- In-progress meetings textbox -->
                                <TextBlock x:Name="txbkMeetingsInProgressValue"
                                    FontSize="16"
                                    Foreground="Orange"
                                    Text="0 In-Progress" />

                                <!-- Separator -->
                                <TextBlock x:Name="txbkMeetingsSeparator2"
                                    FontSize="16"
                                    Text=" / " />

                                <!-- Expired meetings textbox -->
                                <TextBlock x:Name="txbkMeetingsExpiredValue"
                                    FontSize="16"
                                    Foreground="Red"
                                    Text="0 Expired" />

                                <!-- Separator -->
                                <TextBlock x:Name="txbkMeetingsSeparator3"
                                    FontSize="16"
                                    Text=" / " />

                                <!-- Cancelled meetings textbox -->
                                <TextBlock x:Name="txbkMeetingsCancelledValue"
                                    FontSize="16"
                                    Foreground="Black"
                                    Text="0 Cancelled" />

                                <!-- Separator -->
                                <TextBlock x:Name="txbkMeetingsSeparator4"
                                    FontSize="16"
                                    Text=" / " />

                                <!-- Scheduled meetings textbox -->
                                <TextBlock x:Name="txbkMeetingsScheduledValue"
                                    FontSize="16"
                                    Foreground="Gray"
                                    Text="0 Scheduled" />
                            </StackPanel>

                            <!--
                                Meeting result list datagrid
                                Displays the user meeting with some special effects.
                            -->
                            <DataGrid x:Name="dgrdMeetingList"
                                Height="120"
                                MaxHeight="120"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                CanUserResizeRows="False"
                                CanUserSortColumns="True"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                SelectionChanged="dgMeetingResults_SelectionChanged"
                                SelectionMode="Single"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <!-- Style for meeting rows -->
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <!-- Cancelled meetings: light gray text -->
                                            <DataTrigger
                                                Binding="{Binding IsCancelled}"
                                                Value="True">
                                                <Setter Property="Foreground" Value="LightGray" />
                                            </DataTrigger>
                                            <!-- Completed meetings: bold text -->
                                            <DataTrigger
                                                Binding="{Binding IsCompleted}"
                                                Value="True">
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <!-- Style for Meeting ID cells with errors -->
                                    <Style
                                        x:Key="MeetingIdCellStyle"
                                        TargetType="DataGridCell">
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding HasError}"
                                                Value="True">
                                                <Setter Property="Background" Value="LightSalmon" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <!-- ID -->
                                    <DataGridTextColumn
                                        Width="80"
                                        Binding="{Binding MeetingId}"
                                        CellStyle="{StaticResource MeetingIdCellStyle}"
                                        Header="ID" />
                                    <!-- Scheduled start date/time -->
                                    <DataGridTextColumn
                                        Width="135"
                                        Binding="{Binding ScheduledStart}"
                                        Header="Scheduled Start" />
                                    <!-- Actual start date/time -->
                                    <DataGridTextColumn
                                        Width="135"
                                        Binding="{Binding ActualStart}"
                                        Header="Actual Start Time" />
                                    <!-- Scheduled end date/time -->
                                    <DataGridTextColumn
                                        Width="135"
                                        Binding="{Binding ScheduledEnd}"
                                        Header="Scheduled End Time" />
                                    <!-- Actual end date/time -->
                                    <DataGridTextColumn
                                        Width="135"
                                        Binding="{Binding ActualEnd}"
                                        Header="Actual End Time" />
                                    <!-- Duration -->
                                    <DataGridTextColumn
                                        Width="60"
                                        Binding="{Binding Duration}"
                                        Header="Duration" />
                                    <!-- Status -->
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Status}"
                                        Header="Status" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                        <!--
                            Meeting detail panel
                            Contains the general and user meeting detail sections.
                        -->
                        <StackPanel x:Name="spnlMeetingDetail"
                            Width="807"
                            Margin="0,10,0,0"
                            Orientation="Vertical">

                            <!--
                                General meeting detail border
                                This visible for both patient and provider search modes.
                            -->
                            <Border x:Name="brdrGeneralMeetingDetail"
                                Margin="0,0,0,0"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="5">

                                <!--
                                    General meeting detail panel
                                -->
                                <StackPanel x:Name="spnlGeneralMeetingDetail"
                                    Margin="5,5,0,0">

                                    <!--
                                        General meeting detail top panel
                                        Contains the header and copy button for the general meeting details section.
                                    -->
                                    <StackPanel x:Name="spnlGeneralMeetingDetailTop"
                                        Margin="0,0,0,4"
                                        Orientation="Horizontal">

                                        <!-- General meeting detail header -->
                                        <TextBlock x:Name="txbkGeneralMeetingDetailHeader"
                                            Margin="0,5,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Meeting Details" />

                                        <!-- General meeting detail copy button -->
                                        <Button x:Name="btnCopyGeneralMeetingDetail"
                                            Width="24"
                                            Height="24"
                                            Margin="10,0,0,0"
                                            BorderThickness="0"
                                            Click="btnCopyGeneralMeetingDetail_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3" />
                                                </Style>
                                            </Button.Resources>
                                            <Button.Background>
                                                <ImageBrush ImageSource="/AppData/Image/Control/Button/Copy-40x40.png" />
                                            </Button.Background>
                                        </Button>
                                    </StackPanel>

                                    <!--
                                        General meeting detail grid column definitions
                                        Left column: Meeting ID, Title, Status, Joins, Duration, Service code
                                        Center column: Started by, Scheduled start, Actual start, Ended by, Scheduled end, Actual end
                                        Right column: Workflow, Program, Front Desk Check-in, Meeting error
                                    -->
                                    <Grid x:Name="grdGeneralMeetingDetailColumnDefinitions"
                                        Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <!-- Left column definition -->
                                            <ColumnDefinition x:Name="colGeneralMeetingDetailLeftColumnDefinition"
                                                Width="*" />
                                            <!-- Center column definition -->
                                            <ColumnDefinition x:Name="colGeneralMeetingDetailCenterColumnDefinition"
                                                Width="*" />
                                            <!-- Right column definition -->
                                            <ColumnDefinition x:Name="colGeneralMeetingDetailRightColumnDefinition"
                                                Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left column panel -->
                                        <StackPanel x:Name="spnlGeneralMeetingDetailLeftColumn"
                                            Grid.Column="0"
                                            Margin="0,0,10,0">

                                            <!-- Meeting ID panel -->
                                            <StackPanel x:Name="spnlMeetingId"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Meeting ID label -->
                                                <TextBlock x:Name="txbkMeetingIdKey"
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Meeting ID:" />

                                                <!-- Meeting ID value -->
                                                <TextBlock x:Name="txbkMeetingIdValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Meeting title panel -->
                                            <StackPanel x:Name="spnlMeetingTitle"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Meeting title label -->
                                                <TextBlock x:Name="txbkMeetingTitleKey"
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Title:" />

                                                <!-- Meeting title value -->
                                                <TextBlock x:Name="txbkMeetingTitleValue"
                                                    FontSize="11"
                                                    Text="---"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>

                                            <!-- Meeting status panel -->
                                            <StackPanel x:Name="spnlMeetingStatus"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Meeting status label -->
                                                <TextBlock x:Name="txbkMeetingStatusKey"
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Status:" />

                                                <!-- Meeting status value -->
                                                <TextBlock x:Name="txbkMeetingStatusValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Meeting joins panel -->
                                            <StackPanel x:Name="spnlMeetingJoins"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Meeting joins label -->
                                                <TextBlock x:Name="txbkMeetingJoinsKey"
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Joins:" />

                                                <!-- Meeting joins value -->
                                                <TextBlock x:Name="txbkMeetingJoinsValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Meeting duration panel -->
                                            <StackPanel x:Name="spnlMeetingDuration"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Meeting duration label -->
                                                <TextBlock x:Name="txbkMeetingDurationKey"
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Duration:" />

                                                <!-- Meeting duration value -->
                                                <TextBlock x:Name="txbkMeetingDurationValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Service code panel -->
                                            <StackPanel x:Name="spnlMeetingServiceCode"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Service code label -->
                                                <TextBlock x:Name="txbkMeetingServiceCodeKey"
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Service code:" />

                                                <!-- Service code value -->
                                                <TextBlock x:Name="txbkMeetingServiceCodeValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Center column -->
                                        <StackPanel x:Name="spnlGeneralMeetingDetailCenterColumn"
                                            Grid.Column="1"
                                            Margin="0,0,10,0">

                                            <!-- Started by panel -->
                                            <StackPanel x:Name="spnlMeetingStartedBy"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Started by label -->
                                                <TextBlock x:Name="txbkMeetingStartedByKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Started by:" />

                                                <!-- Started by value -->
                                                <TextBlock x:Name="txbkMeetingStartedByValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Scheduled start panel -->
                                            <StackPanel x:Name="spnlMeetingScheduledStart"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Scheduled start label -->
                                                <TextBlock x:Name="txbkMeetingScheduledStartKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Scheduled start:" />

                                                <!-- Scheduled start value -->
                                                <TextBlock x:Name="txbkMeetingScheduledStartValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Actual start panel -->
                                            <StackPanel x:Name="spnlMeetingActualStart"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Actual start label -->
                                                <TextBlock x:Name="txbkMeetingActualStartKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Actual start:" />

                                                <!-- Actual start value -->
                                                <TextBlock x:Name="txbkMeetingActualStartValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Ended by panel -->
                                            <StackPanel x:Name="spnlMeetingEndedBy"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Ended by label -->
                                                <TextBlock x:Name="txbkMeetingEndedByKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
