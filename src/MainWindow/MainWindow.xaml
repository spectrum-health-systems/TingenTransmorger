                            </Border>

                            <!--
                                Patient meeting detail panel
                                Contains patient-specific meeting details and is visible only in patient search mode.
                            -->
                            <Border x:Name="brdrPatientMeetingDetail"
                                Margin="0,10,0,0"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="5">

                                <!-- Patient meeting details panel -->
                                <StackPanel x:Name="spnlPatientMeetingDetail"
                                    Margin="8">

                                    <!--
                                        Patient meeting detail top panel
                                        Contains the header and copy button for the patient meeting details section.
                                    -->
                                    <StackPanel x:Name="spnlPatientMeetingDetailTop"
                                        Margin="0,0,0,4"
                                        Orientation="Horizontal">

                                        <!-- Header -->
                                        <TextBlock x:Name="txbkPatientMeetingDetailHeader"
                                            Margin="0,5,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Meeting Details (Patient)" />

                                        <!-- Copy button -->
                                        <Button x:Name="btnCopyPatientMeetingDetail"
                                            Width="24"
                                            Height="24"
                                            Margin="10,0,0,0"
                                            BorderThickness="0"
                                            Click="btnCopyPatientMeetingDetail_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3" />
                                                </Style>
                                            </Button.Resources>
                                            <Button.Background>
                                                <ImageBrush ImageSource="/AppData/Image/Control/Button/Copy-40x40.png" />
                                            </Button.Background>
                                        </Button>
                                    </StackPanel>

                                    <!--
                                        Patient meeting detail grid column definitions
                                        Left column: Patient arrived, Patient dropped, Duration, Rating
                                        Center column: Checked-In via chat, Check-In wait, Wait for Care Team member, Wait for provider, Check out wait
                                        Right column: Device, Operating System, Browser
                                    -->
                                    <Grid x:Name="grdPatientMeetingDetailColumnDefinitions"
                                        Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <!-- Left column -->
                                            <ColumnDefinition x:Name="colPatientMeetingDetailLeftColumnDefinition"
                                                Width="201*" />
                                            <ColumnDefinition Width="49*" />
                                            <!-- Center column -->
                                            <ColumnDefinition x:Name="colPatientMeetingDetailCenterColumnDefinition"
                                                Width="250*" />
                                            <!-- Right column -->
                                            <ColumnDefinition x:Name="colPatientMeetingDetailRightColumnDefinition"
                                                Width="250*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left column panel -->
                                        <StackPanel x:Name="spnlPatientMeetingDetailLeftColumn"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Margin="0,0,10,0">

                                            <!-- Patient arrived panel -->
                                            <StackPanel x:Name="spnlPatientArrived"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Patient arrived key -->
                                                <TextBlock x:Name="txbkPatientArrivedKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Patient arrived:" />

                                                <!-- Patient arrived value -->
                                                <TextBlock x:Name="txbkPatientArrivedValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Patient dropped panel -->
                                            <StackPanel x:Name="spnlPatientDropped"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Patient dropped key -->
                                                <TextBlock x:Name="txbkPatientDroppedKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Patient dropped:" />

                                                <!-- Patient dropped value -->
                                                <TextBlock x:Name="txbkPatientDroppedValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Duration panel -->
                                            <StackPanel x:Name="spnlPatientDuration"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Duration key -->
                                                <TextBlock x:Name="txbkPatientDurationKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Duration:" />

                                                <!-- Duration value -->
                                                <TextBlock x:Name="txbkPatientDurationValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Rating panel -->
                                            <StackPanel x:Name="spnlPatientRating"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Rating key -->
                                                <TextBlock x:Name="txbkPatientRatingKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Rating:" />

                                                <!-- Rating value -->
                                                <TextBlock x:Name="txbkPatientRatingValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Center column panel -->
                                        <StackPanel x:Name="spnlPatientMeetingDetailCenterColumn"
                                            Grid.Column="2"
                                            Margin="0,0,10,0">

                                            <!-- Checked-In via chat panel -->
                                            <StackPanel x:Name="spnlCheckedInViaChat"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Checked-In via chat key -->
                                                <TextBlock x:Name="txbkCheckedInViaChatKey"
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Checked-In via chat:" />

                                                <!-- Checked-In via chat value -->
                                                <TextBlock x:Name="txbkCheckedInViaChatValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Check-In wait panel -->
                                            <StackPanel x:Name="spnlCheckInWait"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Check-In wait key -->
                                                <TextBlock x:Name="txbkCheckInWaitKey"
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Check-In wait:" />

                                                <!-- Check-In wait value -->
                                                <TextBlock x:Name="txbkCheckInWaitValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Wait for Care Team panel -->
                                            <StackPanel x:Name="spnlWaitForCareTeam"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Wait for Care Team key -->
                                                <TextBlock x:Name="txbkWaitForCareTeamKey"
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Wait for Care Team:" />

                                                <!-- Wait for Care Team value -->
                                                <TextBlock x:Name="txbkWaitForCareTeamValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Wait for provider panel -->
                                            <StackPanel x:Name="spnlWaitForProvider"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Wait for provider key -->
                                                <TextBlock x:Name="txbkWaitForProviderKey"
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Wait for provider:" />

                                                <!-- Wait for provider value -->
                                                <TextBlock x:Name="txbkWaitForProviderValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>

                                            <!-- Check out wait panel -->
                                            <StackPanel x:Name="spnlCheckOutWait"
                                                Margin="0,2"
                                                Orientation="Horizontal">

