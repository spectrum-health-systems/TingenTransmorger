<Window x:Class="TingenTransmorger.Database.DiagnosticWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Database Diagnostic" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Diagnostic Text Display -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox
                    x:Name="txtDiagnostic"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    FontFamily="Consolas"
                    FontSize="12"
                    Padding="10"
                    BorderThickness="0"
                    Background="White"
                    AcceptsReturn="True"
                    VerticalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button
                x:Name="btnCopyToClipboard"
                Width="140"
                Height="35"
                Margin="0,0,10,0"
                Content="Copy to Clipboard"
                FontSize="14"
                FontWeight="SemiBold"
                Click="btnCopyToClipboard_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button
                x:Name="btnClose"
                Width="100"
                Height="35"
                Content="Close"
                FontSize="14"
                FontWeight="SemiBold"
                Click="btnClose_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
