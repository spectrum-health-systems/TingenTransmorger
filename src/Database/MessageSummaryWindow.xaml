<Window x:Class="TingenTransmorger.Database.MessageSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TingenTransmorger.Database"
        mc:Ignorable="d"
        Title="Message Summary" Height="600" Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <!--  Combined Messages Section  -->
            <Border BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold" Text="Message History (Most Recent First)" Margin="0,0,0,10"/>
                    <DataGrid
                            x:Name="dgMessages"
                            Height="342"
                            MaxHeight="480"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            CanUserResizeRows="False"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            VerticalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFailure}" Value="True">
                                        <Setter Property="Background" Value="LightSalmon"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFailure}" Value="False">
                                        <Setter Property="Background" Value="LightGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                    Width="140"
                                    Binding="{Binding Sent}"
                                    Header="Sent" />
                            <DataGridTextColumn
                                    Width="160"
                                    Binding="{Binding ScheduleStartTime}"
                                    Header="Start Time" />
                            <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding Status}"
                                    Header="Status" />
                            <DataGridTextColumn
                                    Width="140"
                                    Binding="{Binding MessageType}"
                                    Header="Message Type" />
                            <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding ErrorDetails}"
                                    Header="Error/Details" />
                            <DataGridTextColumn
                                    Width="110"
                                    Binding="{Binding PhoneNumber}"
                                    Header="Phone Number" />
                            <DataGridTextColumn
                                    Width="80"
                                    Binding="{Binding Type}"
                                    Header="Type" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!--  Close Button  -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button
                x:Name="btnClose"
                Width="100"
                Height="35"
                Margin="0,10,0,0"
                Content="Close"
                FontSize="14"
                FontWeight="SemiBold"
                Click="btnClose_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>

