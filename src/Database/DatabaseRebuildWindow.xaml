<Window
    x:Class="TingenTransmorger.Database.DatabaseRebuildWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tingen Transmorger: Database Rebuild"
    Width="500"
    Height="250"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Border around the entire window  -->
        <Border
            x:Name="brdrWindow"
            Padding="10"
            Background="White"
            BorderBrush="LawnGreen"
            BorderThickness="2"
            CornerRadius="5">
            <!--  StackPanel to hold all components vertically  -->
            <StackPanel x:Name="spnlComponents" Orientation="Vertical">
                <!--  Title  -->
                <Label
                    x:Name="lblRebuildTitle"
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Content="Rebuilding Transmorger database"
                    FontSize="18"
                    FontWeight="Bold" />
                <!--  Current task  -->
                <TextBlock
                    x:Name="txbkCurrentTask"
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    FontSize="14"
                    Text="Initializing..." />
                <!--  Progress bar  -->
                <ProgressBar
                    x:Name="pbarProgress"
                    Grid.Row="2"
                    Height="30"
                    Maximum="100"
                    Minimum="0"
                    Value="0" />
                <!--  Rebuild status  -->
                <TextBlock
                    x:Name="txbkStatus"
                    Grid.Row="3"
                    Margin="0,10,0,0"
                    FontSize="12"
                    Foreground="Gray"
                    Text="Starting..." />
                <!--  Close button  -->
                <Button
                    x:Name="btnClose"
                    Grid.Row="4"
                    Width="100"
                    Height="30"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Click="btnClose_Click"
                    Content="Close"
                    Visibility="Collapsed">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
