                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Right column panel -->
                                        <StackPanel x:Name="spnlPatientMeetingDetailRightColumn"
                                            Grid.Column="3">

                                            <!-- Device panel -->
                                            <StackPanel x:Name="spnlPatientDevice"
                                                Margin="0,2"
                                                Orientation="Horizontal">

                                                <!-- Device label -->
                                                <TextBlock x:Name="txbkPatientDeviceKey"
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
