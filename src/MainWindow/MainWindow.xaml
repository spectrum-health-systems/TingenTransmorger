<!--
    This is the main window of the Tingen Transmorger application. I am not a UI designer, so it probably breaks a
    number of UI best practices, but I did my best! To that point, this window has a resolution of 1200x700, and is not
    designed to be resized.
    
    I've provided detailed comments throughout the XAML to explain the structure and purpose of each element in the UI,
    and the code-behind contains is written to be as clear as possible.
    
    A few things of note:
    
    The brdrMainContainer control will be different colors, depending on what type of user is running the application;
    standard users will see a SteelBlue background, admin users will see a DarkRed background
    
    The btnSearchToggle control toggles between patient and provider search modes.
    
    When in patient search mode:
    - The brdrMeetingDetailsPatient control is visible
    - The spnlPatientPhoneAndEmail control is visible
    - The brdrMeetingDetailsProvider control is hidden
    
    When in provider search mode:
    - The spnlPatientPhoneAndEmail control is hidden
    - The brdrMeetingDetailsProvider control is visible
    - The brdrMeetingDetailsPatient control is hidden
-->

<Window
    x:Class="TingenTransmorger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TingenTransmorger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tingen Transmorger"
    Width="1200"
    Height="700"
    ResizeMode="NoResize"
    mc:Ignorable="d">

    <!-- The main grid. -->
    <Grid x:Name="gridMainContainer">

        <!-- The main border that holds all of the UI -->
        <Border x:Name="brdrMainContainer"
            Margin="10"
            Background="SteelBlue">
            <Border.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10" />
                </Style>
            </Border.Resources>

            <!--
                The grid that contains the two main columns of the UI.
                A :
                - The left column will be for searching patients/providers
                - The right column will be for displaying details about the selected patient/provider and their meetings.
            -->
            <Grid x:Name="gridMainColumnsContainer">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="colLeftColumn"
                        Width="360" />
                    <ColumnDefinition x:Name="colRightColumn"
                        Width="*" />
                </Grid.ColumnDefinitions>
                <!-- LEFT COLUMN BORDER -->
                <Border x:Name="brdrLeftColumn"
                    Grid.Column="0"
                    Margin="12,12,4,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="6,0,0,6">
                    <!-- StackPanel to hold search options, search bar, and search results -->
                    <StackPanel x:Name="spnlSearchContainer"
                        Orientation="Vertical">
                        <!-- Search options: patient/provider toggle and search by name/ID radio buttons -->
                        <StackPanel x:Name="spnlSearchOptions"
                            Grid.Column="0"
                            Background="White"
                            Orientation="Horizontal">
                            <!-- Button to toggle between patient/provider searches -->
                            <Button x:Name="btnSearchToggle"
                                Width="200"
                                Height="42"
                                Margin="10,10,0,8"
                                HorizontalAlignment="left"
                                Click="btnSearchToggle_Click"
                                Content="Patient Search"
                                FontSize="18"
                                FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <!-- Radio buttons to toggle between searching by name or ID -->
                            <StackPanel x:Name="spnlSearchByNameOrId"
                                Orientation="Vertical">
                                <!-- Radio button to search by name -->
                                <RadioButton x:Name="rbtnByName"
                                    Width="116"
                                    Margin="5,12,0,0"
                                    VerticalContentAlignment="Center"
                                    Checked="rbtnSearch_Checked"
                                    Content="By name"
                                    FontSize="14" />
                                <!-- Radio button to search by ID -->
                                <RadioButton x:Name="rbtnById"
                                    Width="116"
                                    Margin="5,5,0,0"
                                    VerticalContentAlignment="Center"
                                    Checked="rbtnSearch_Checked"
                                    Content="By ID"
                                    FontSize="14" />
                            </StackPanel>
                        </StackPanel>
                        <!-- Search bar and search results listbox -->
                        <StackPanel x:Name="spnlSearchBar"
                            Margin="0,0,0,6"
                            Orientation="Horizontal">
                            <!-- Search bar -->
                            <TextBox x:Name="txbxSearch"
                                Width="310"
                                Height="32"
                                Margin="10,0,8,0"
                                Padding="10,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                TextChanged="txbxSearch_TextChanged">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        <!-- ListBox to display search results -->
                        <ListBox x:Name="lstbxSearchResults"
                            Height="476"
                            SelectionChanged="lstbxSearchResults_SelectionChanged">
                            <ListBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="7" />
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </StackPanel>
                </Border>
                <!-- RIGHT COLUMN BORDER -->
                <Border x:Name="brdrRightPanel"
                    Grid.Column="1"
                    Margin="4,12,12,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="0,6,6,0">
                    <!-- StackPanel for both patient/provider details -->
                    <StackPanel x:Name="spnlDetailsMain">
                        <!-- StackPanel for patient/provider name, and patient phone/email. -->
                        <StackPanel x:Name="spnlNamePhoneEmail"
                            Height="65"
                            Margin="0"
                            Background="White"
                            Orientation="Horizontal">
                            <!-- Patient/provider label -->
                            <Label x:Name="lblPatientProviderKey"
                                Width="100"
                                Height="64"
                                Margin="0,-1,0,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Black"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="PATIENT"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="White">
                                <Label.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5,0,0,5" />
                                    </Style>
                                </Label.Resources>
                            </Label>
                            <!-- Patient/provider name and ID -->
                            <StackPanel x:Name="spnlPatientProviderNameAndId"
                                Orientation="vertical">
                                <!-- Patient/provider Name -->
                                <Label x:Name="lblPatientProviderNameValue"
                                    Width="250"
                                    Height="32"
                                    Margin="0,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    BorderBrush="Black"
                                    BorderThickness="1,1,1,0"
                                    Content="----------------------------------"
                                    FontSize="16"
                                    FontWeight="SemiBold">
                                    <Label.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,5,0,0" />
                                        </Style>
                                    </Label.Resources>
                                </Label>
                                <!-- Patient/provider ID -->
                                <Label x:Name="lblPatientProviderIdValue"
                                    Width="250"
                                    Height="32"
                                    Margin="0,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1,0,1,1"
                                    Content="---------------------------------------"
                                    FontSize="14"
                                    FontWeight="Regular"
                                    Foreground="Black">
                                    <Label.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,0,5,0" />
                                        </Style>
                                    </Label.Resources>
                                </Label>
                            </StackPanel>
                            <!-- Patient phone and email -->
                            <StackPanel x:Name="spnlPatientPhoneAndEmail"
                                Orientation="Vertical">
                                <!-- Patient phone -->
                                <StackPanel x:Name="spnlPatientPhone"
                                    Orientation="Horizontal">
                                    <!-- Patient phone label -->
                                    <Label x:Name="lblPatientPhoneKey"
                                        Width="60"
                                        Height="30"
                                        Margin="5,0,0,4"
                                        HorizontalContentAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        Background="Black"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        Content="Phone"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5,0,0,5" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <!-- Patient phone number -->
                                    <Label x:Name="lblPatientPhoneValue"
                                        Width="325"
                                        Height="30"
                                        Margin="0,0,0,4"
                                        Padding="0,0,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="Black"
                                        BorderThickness="1,1,0,1"
                                        Content="------------------------------------------------"
                                        FontSize="16"
                                        FontWeight="SemiBold">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,0" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <!-- Button to view patient phone details -->
                                    <Button x:Name="btnPhoneDetails"
                                        Width="32"
                                        Height="30"
                                        Margin="0,0,0,4"
                                        Click="btnPhoneDetails_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,5,5,0" />
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                                <!-- Patient email -->
                                <StackPanel x:Name="spnlPatientEmail"
                                    Orientation="Horizontal">
                                    <!--  -->
                                    <Label x:Name="lblPatientEmailKey"
                                        Width="60"
                                        Height="30"
                                        Margin="5,0,0,0"
                                        HorizontalContentAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        Background="Black"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        Content="Email"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5,0,0,5" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <!--  -->
                                    <Label x:Name="lblPatientEmailValue"
                                        Width="325"
                                        Height="30"
                                        Margin="0,0,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="Black"
                                        BorderThickness="1,1,0,1"
                                        Content="----------------------------------------------------------------"
                                        FontSize="12"
                                        FontWeight="Regular">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,0" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <!--  -->
                                    <Button x:Name="btnEmailDetails"
                                        Width="32"
                                        Height="30"
                                        Margin="0,0,0,0"
                                        Click="btnEmailDetails_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,5,5,0" />
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <!-- Patient/provider meeting information -->
                        <StackPanel x:Name="spnlPatientProviderMeetings"
                            Margin="0,10,0,0">
                            <!-- Meeting details -->
                            <StackPanel x:Name="spnlMeetingsHeader"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <!-- Total meetings -->
                                <TextBlock x:Name="txtMeetingsTotal"
                                    Margin="0,0,5,0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Meetings" />
                                <!-- Completed meetings -->
                                <TextBlock x:Name="txtMeetingsCompleted"
                                    FontSize="16"
                                    Foreground="Green"
                                    Text="0 Completed" />
                                <!-- Separator -->
                                <TextBlock x:Name="txtMeetingsSeparator1"
                                    FontSize="16"
                                    Text=" / " />
                                <!-- In-progress meetings -->
                                <TextBlock x:Name="txtMeetingsInProgress"
                                    FontSize="16"
                                    Foreground="Orange"
                                    Text="0 In-Progress" />
                                <!-- Separator -->
                                <TextBlock x:Name="txtMeetingsSeparator2"
                                    FontSize="16"
                                    Text=" / " />
                                <!-- Expired meetings -->
                                <TextBlock x:Name="txtMeetingsExpired"
                                    FontSize="16"
                                    Foreground="Red"
                                    Text="0 Expired" />
                                <!-- Separator -->
                                <TextBlock x:Name="txtMeetingsSeparator3"
                                    FontSize="16"
                                    Text=" / " />
                                <!-- Cancelled meetings -->
                                <TextBlock x:Name="txtMeetingsCancelled"
                                    FontSize="16"
                                    Foreground="Black"
                                    Text="0 Cancelled" />
                                <!-- Separator -->
                                <TextBlock x:Name="txtMeetingsSeparator4"
                                    FontSize="16"
                                    Text=" / " />
                                <!-- Scheduled meetings -->
                                <TextBlock x:Name="txtMeetingsScheduled"
                                    FontSize="16"
                                    Foreground="Gray"
                                    Text="0 Scheduled" />
                            </StackPanel>
                            <!-- DataGrid to display patient/provider meetings -->
                            <DataGrid x:Name="dgPatientProviderMeetings"
                                Height="120"
                                MaxHeight="120"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                CanUserResizeRows="False"
                                CanUserSortColumns="True"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                SelectionChanged="dgPatientMeetings_SelectionChanged"
                                SelectionMode="Single"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <!-- Style for meeting rows -->
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <!-- Cancelled meetings: light gray text -->
                                            <DataTrigger
                                                Binding="{Binding IsCancelled}"
                                                Value="True">
                                                <Setter Property="Foreground" Value="LightGray" />
                                            </DataTrigger>
                                            <!-- Completed meetings: bold text -->
                                            <DataTrigger
                                                Binding="{Binding IsCompleted}"
                                                Value="True">
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <!-- Style for Meeting ID cells with errors -->
                                    <Style
                                        x:Key="MeetingIdCellStyle"
                                        TargetType="DataGridCell">
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding HasError}"
                                                Value="True">
                                                <Setter Property="Background" Value="LightSalmon" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <!-- Meeting ID -->
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding MeetingId}"
                                        CellStyle="{StaticResource MeetingIdCellStyle}"
                                        Header="ID" />
                                    <!-- Meeting scheduled start date/time -->
                                    <DataGridTextColumn
                                        Width="150"
                                        Binding="{Binding Start}"
                                        Header="Scheduled Start" />
                                    <!-- Patient arrived date/time -->
                                    <DataGridTextColumn
                                        Width="150"
                                        Binding="{Binding Arrived}"
                                        Header="Patient Arrived" />
                                    <!-- Patient dropped date/time -->
                                    <DataGridTextColumn
                                        Width="150"
                                        Binding="{Binding Dropped}"
                                        Header="Patient Dropped" />
                                    <!-- Patient duration -->
                                    <DataGridTextColumn
                                        Width="110"
                                        Binding="{Binding Duration}"
                                        Header="Patient Duration" />
                                    <!-- Meeting status -->
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Status}"
                                        Header="Status" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                        <!--
                            StackPanel that contains the following:
                            - Meeting Details (General)
                            - Meeting Details (Patient)
                            - Meeting Details (Provider)
                        -->
                        <StackPanel x:Name="spnlMeetingDetails"
                            Width="788"
                            Margin="0,10,20,0"
                            Orientation="Vertical">
                            <!-- Meeting Details (General) -->
                            <Border x:Name="brdrMeetingDetailsGeneral"
                                Margin="0,0,20,0"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="5">
                                <!--
                                    StackPanel to hold Meeting Details (General) information, which consists of:
                                    - The top row, containing the title and the copy button.
                                    - The bottom row, containing a 3-column grid meeting information.
                                -->
                                <StackPanel x:Name="spnlMeetingDetailsGeneral"
                                    Margin="5,5,0,0">
                                    <!-- Stackpanel containing the Meeting Details (General) information -->
                                    <StackPanel x:Name="spnlMeetingDetailsGeneralContainer"
                                        Margin="0,0,0,4"
                                        Orientation="Horizontal">
                                        <!-- Meeting Details (General) header -->
                                        <TextBlock x:Name="txtMeetingDetailsHeader"
                                            Margin="0,5,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Meeting Details (General)" />
                                        <!-- Button to copy Meeting Details (General) information to clipboard -->
                                        <Button x:Name="btnCopyMeetingDetailsGeneral"
                                            Width="24"
                                            Height="24"
                                            Margin="10,0,0,0"
                                            BorderThickness="0"
                                            Click="btnCopyMeetingDetailsGeneral_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3" />
                                                </Style>
                                            </Button.Resources>
                                            <Button.Background>
                                                <ImageBrush ImageSource="/AppData/Image/Control/Button/Copy-40x40.png" />
                                            </Button.Background>
                                        </Button>
                                    </StackPanel>
                                    <!--
                                        Bottom row with 3-column grid:
                                        - Left column: Meeting ID, Title, Status, Joins, Duration, Service code
                                        - Center column: Started by, Scheduled start, Actual start, Ended by, Scheduled end, Actual end
                                        - Right column: Workflow, Program, Front Desk Check-in, Meeting error
                                    -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Left column -->
                                        <StackPanel
                                            Grid.Column="0"
                                            Margin="0,0,10,0">
                                            <!-- Meeting ID -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <!--  -->
                                                <TextBlock
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Meeting ID:" />
                                                <!-- Meeting ID value -->
                                                <TextBlock x:Name="lblMeetingIdValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Meeting Title -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <!-- Meeting Title -->
                                                <TextBlock
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Title:" />
                                                <!-- Meeting Title value -->
                                                <TextBlock x:Name="lblMeetingTitleValue"
                                                    FontSize="11"
                                                    Text="---"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <!-- Meeting Status -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <!-- Meeting Status -->
                                                <TextBlock
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Status:" />
                                                <!-- Meeting Status value -->
                                                <TextBlock x:Name="lblMeetingStatusValue"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Meeting joins -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <!-- Meeting joins label -->
                                                <TextBlock
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Joins:" />
                                                <!-- Meeting joins value -->
                                                <TextBlock x:Name="lblMeetingJoins"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Meeting duration -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <!-- Meeting duration label -->
                                                <TextBlock
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Duration:" />
                                                <!-- Meeting duration value -->
                                                <TextBlock x:Name="lblMeetingDuration"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Service Code -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="80"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Service code:" />
                                                <TextBlock x:Name="lblMeetingServiceCode"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- CENTER COLUMN -->
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="0,0,10,0">
                                            <!-- Started by -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Started by:" />
                                                <TextBlock x:Name="lblMeetingInitiatedBy"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Scheduled start -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Scheduled start:" />
                                                <TextBlock x:Name="lblMeetingScheduledStart"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Actual start -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Actual start:" />
                                                <TextBlock x:Name="lblMeetingActualStart"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Ended by -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Ended by:" />
                                                <TextBlock x:Name="lblMeetingEndedBy"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Scheduled end -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Scheduled end:" />
                                                <TextBlock x:Name="lblMeetingScheduledEnd"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Actual end -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Actual end:" />
                                                <TextBlock x:Name="lblMeetingActualEnd"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- RIGHT COLUMN -->
                                        <StackPanel Grid.Column="2">
                                            <!-- Workflow -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Workflow:" />
                                                <TextBlock x:Name="txtMeetingWorkflow"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Program -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Program:" />
                                                <TextBlock x:Name="txtMeetingProgram"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Front Desk Check-in -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="116"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Front Desk Check-In:" />
                                                <TextBlock x:Name="txtMeetingCheckedInByFrontDesk"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Meeting Error -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Vertical">
                                                <TextBlock
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Meeting error:" />
                                                <TextBlock x:Name="txtMeetingError"
                                                    Margin="0,2,0,0"
                                                    FontSize="11"
                                                    Text="---"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>


                            <!-- Meeting Details (Patient) Section -->
                            <Border x:Name="brdrMeetingDetailsPatient"
                                Margin="0,10,20,0"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="5">
                                <StackPanel x:Name="spnlMeetingDetailsPatient"
                                    Margin="8">
                                    <StackPanel
                                        Margin="0,0,0,4"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,5,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Meeting Details (Patient)" />
                                        <Button x:Name="btnCopyMeetingDetailsPatient"
                                            Width="24"
                                            Height="24"
                                            Margin="10,0,0,0"
                                            BorderThickness="0"
                                            Click="btnCopyMeetingDetailsPatient_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3" />
                                                </Style>
                                            </Button.Resources>
                                            <Button.Background>
                                                <ImageBrush ImageSource="/AppData/Image/Control/Button/Copy-40x40.png" />
                                            </Button.Background>
                                        </Button>
                                    </StackPanel>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- LEFT COLUMN -->
                                        <StackPanel
                                            Grid.Column="0"
                                            Margin="0,0,10,0">
                                            <!-- Patient Arrived -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Patient arrived:" />
                                                <TextBlock x:Name="txtPatientArrived"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Patient Dropped -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Patient dropped:" />
                                                <TextBlock x:Name="txtPatientDropped"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Duration -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Duration:" />
                                                <TextBlock x:Name="txtPatientDuration"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Rating -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Rating:" />
                                                <TextBlock x:Name="txtPatientRating"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- CENTER COLUMN -->
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="0,0,10,0">
                                            <!-- Checked-In via chat -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Checked-In via chat:" />
                                                <TextBlock x:Name="txtCheckInViaChat"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Check-In wait -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Check-In wait:" />
                                                <TextBlock x:Name="txtCheckInWait"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Wait for Care Team member -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Wait for Care Team:" />
                                                <TextBlock x:Name="txtWaitForCareTeam"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Wait for provider -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Wait for provider:" />
                                                <TextBlock x:Name="txtWaitForProvider"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Check out wait -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="130"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Check-out wait:" />
                                                <TextBlock x:Name="txtCheckOutWait"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- RIGHT COLUMN -->
                                        <StackPanel Grid.Column="2">
                                            <!-- Device -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Device:" />
                                                <TextBlock x:Name="txtPatientDevice"
                                                    FontSize="11"
                                                    Text="---" />
                                            </StackPanel>
                                            <!-- Operating System -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="OS:" />
                                                <TextBlock x:Name="txtPatientOs"
                                                    FontSize="11"
                                                    Text="---"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <!-- Browser -->
                                            <StackPanel
                                                Margin="0,2"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Width="90"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="Browser:" />
                                                <TextBlock x:Name="txtPatientBrowser"
                                                    FontSize="11"
                                                    Text="---"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Participant Meeting Quality Data - Spanning all columns -->
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="Participant Meeting Quality Data:" />
                                        <TextBlock x:Name="txtMeetingQualityData"
                                            Margin="0,2,0,0"
                                            FontSize="11"
                                            Text="---"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Meeting Details (Provider) Section -->
                            <Border x:Name="brdrMeetingDetailsProvider"
                                Margin="0,10,20,0"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="5">
                                <StackPanel x:Name="spnlMeetingDetailsProvider"
                                    Margin="8">
                                    <StackPanel
                                        Margin="0,0,0,4"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,5,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Meeting Details (Provider)" />
                                        <Button x:Name="btnCopyMeetingDetailsProvider"
                                            Width="24"
                                            Height="24"
                                            Margin="10,0,0,0"
                                            BorderThickness="0"
                                            Click="btnCopyMeetingDetailsProvider_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3" />
                                                </Style>
                                            </Button.Resources>
                                            <Button.Background>
                                                <ImageBrush ImageSource="/AppData/Image/Control/Button/Copy-40x40.png" />
                                            </Button.Background>
                                        </Button>
                                    </StackPanel>

                                    <!-- Participant Names - Spanning full width -->
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="Participant Names:" />
                                        <TextBlock x:Name="txtProviderParticipantNames"
                                            Margin="0,2,0,0"
                                            FontSize="11"
                                            Text="---"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
