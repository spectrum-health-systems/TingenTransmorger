                                                <TextBlock x:Name="txbkPatientBrowserValue"
                                                    FontSize="11"
                                                    Text="---"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!--
                                        Patient Meeting Quality Data panel
                                        This spans all three columns.
                                    -->
                                    <StackPanel x:Name="spnlPatientMeetingQualityData"
                                        Margin="0,8,0,0">

                                        <!-- Patient Meeting Quality Data label -->
                                        <TextBlock x:Name="txbkPatientMeetingQualityDataKey"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="Patient Meeting Quality Data:" />

                                        <!-- Participant Meeting Quality Data value -->
                                        <TextBlock x:Name="txbkPatientMeetingQualityDataValue"
                                            Margin="0,2,0,0"
                                            FontSize="11"
                                            Text="---"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!--
                                Provider meeting detail border
                                This is only visible for provider search mode.
                            -->
                            <Border x:Name="brdrProviderMeetingDetail"
                                Margin="0,10,0,0"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="5">

                                <!-- Provider meeting detail panel -->
                                <StackPanel x:Name="spnlProviderMeetingDetail"
                                    Margin="8">

                                    <!--
                                        Provider meeting detail top panel
                                        Contains the header and copy button for the provider meeting details section.
                                    -->
                                    <StackPanel x:Name="spnlProviderMeetingDetailTop"
                                        Margin="0,0,0,4"
                                        Orientation="Horizontal">

                                        <!-- Provider meeting detail header -->
                                        <TextBlock x:Name="txbkProviderMeetingDetailHeader"
                                            Margin="0,5,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Meeting Details (Provider)" />

                                        <!-- Provider meeting details copy button -->
                                        <Button x:Name="btnCopyProviderMeetingDetail"
                                            Width="24"
                                            Height="24"
                                            Margin="10,0,0,0"
                                            BorderThickness="0"
                                            Click="btnCopyProviderMeetingDetail_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3" />
                                                </Style>
                                            </Button.Resources>
                                            <Button.Background>
                                                <ImageBrush ImageSource="/AppData/Image/Control/Button/Copy-40x40.png" />
                                            </Button.Background>
                                        </Button>
                                    </StackPanel>

                                    <!--
                                        Participant names panel
                                        This spans the full width.
                                    -->
                                    <StackPanel x:Name="spnlProviderParticipantNames"
                                        Margin="0,8,0,0">

                                        <!-- Provider participant names header -->
                                        <TextBlock x:Name="txbkProviderParticipantNamesHeader"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="Participant Names:" />

                                        <!-- Provider participant names textblock -->
                                        <TextBlock x:Name="txtProviderParticipantNames"
                                            Margin="0,2,0,0"
                                            FontSize="11"
                                            Text="---"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>