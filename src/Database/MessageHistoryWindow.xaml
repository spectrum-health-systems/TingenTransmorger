<Window
    x:Class="TingenTransmorger.Database.MessageHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TingenTransmorger.Database"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Message History"
    Width="1100"
    Height="600"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <!--  Combined Messages Section  -->
            <Border
                Padding="10"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label
                            x:Name="lblMessageHistoryTitle"
                            Margin="10,5,10,10"
                            Content="Message History"
                            FontSize="20"
                            FontWeight="Bold" />
                        <TextBlock
                            x:Name="txbkMessageSummary"
                            Margin="105,15,10,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="# Total messages / # Successful / # Failures" />
                        <Button
                            x:Name="btnCopyTopTenMessageHistory"
                            Width="24"
                            Height="24"
                            Margin="170,0,0,0"
                            BorderThickness="0"
                            Click="btnCopyTopTenMessageHistory_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Button.Resources>
                            <Button.Background>
                                <ImageBrush ImageSource="/AppData/Image/Control/Button/CopyTen-40x40.png" />
                            </Button.Background>
                        </Button>
                        <Button
                            x:Name="btnCopyAllMessageHistory"
                            Width="24"
                            Height="24"
                            Margin="10,0,0,0"
                            BorderThickness="0"
                            Click="btnCopyAllMessageHistory_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Button.Resources>
                            <Button.Background>
                                <ImageBrush ImageSource="/AppData/Image/Control/Button/CopyAll-40x40.png" />
                            </Button.Background>
                        </Button>
                        <Button
                            x:Name="btnCopyAllSuccessMessageHistory"
                            Width="24"
                            Height="24"
                            Margin="10,0,0,0"
                            BorderThickness="0"
                            Click="btnCopyAllSuccessMessageHistory_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Button.Resources>
                            <Button.Background>
                                <ImageBrush ImageSource="/AppData/Image/Control/Button/CopySuccess-40x40.png" />
                            </Button.Background>
                        </Button>
                        <Button
                            x:Name="btnCopyAllErrorMessageHistory"
                            Width="24"
                            Height="24"
                            Margin="10,0,0,0"
                            BorderThickness="0"
                            Click="btnCopyAllErrorMessageHistory_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Button.Resources>
                            <Button.Background>
                                <ImageBrush ImageSource="/AppData/Image/Control/Button/CopyError-40x40.png" />
                            </Button.Background>
                        </Button>
                    </StackPanel>
                    <DataGrid
                        x:Name="dgMessages"
                        Height="420"
                        MaxHeight="420"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="False"
                        CanUserResizeColumns="True"
                        CanUserResizeRows="False"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        VerticalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFailure}" Value="True">
                                        <Setter Property="Background" Value="LightSalmon" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFailure}" Value="False">
                                        <Setter Property="Background" Value="LightGreen" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <!--  Combined Sent / Start Time column  -->
                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding SentOrStartTime}"
                                Header="Sent / Start Time" />
                            <!--  Removed separate Start Time column; other columns unchanged  -->
                            <DataGridTextColumn
                                Width="60"
                                Binding="{Binding Status}"
                                Header="Status" />
                            <DataGridTextColumn
                                Width="180"
                                Binding="{Binding MessageType}"
                                Header="Message Type" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding ErrorDetails}"
                                Header="Error/Details" />
                            <DataGridTextColumn
                                Width="100"
                                Binding="{Binding PhoneNumber}"
                                Header="Phone Number" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding Type}"
                                Header="Type" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!--  Close Button  -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                x:Name="btnClose"
                Width="100"
                Height="35"
                Margin="0,10,0,0"
                Click="btnClose_Click"
                Content="Close"
                FontSize="14"
                FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
