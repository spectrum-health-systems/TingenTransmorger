<Window
    x:Class="TingenTransmorger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TingenTransmorger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tingen Transmorger"
    Width="1200"
    Height="700"
    ResizeMode="NoResize"
    mc:Ignorable="d">
    <Grid>
        <!--  TOP BAR  -->
        <StackPanel x:Name="spnlTop" Orientation="Horizontal">
            <TextBlock
                x:Name="txblTingenTransmorgerTitle"
                Margin="20,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="28"
                FontWeight="Bold"
                Text="Tingen Transmorger" />
            <Button
                x:Name="btnSettings"
                Width="32"
                Height="32"
                Margin="310,15,20,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Content="S"
                FontSize="16"
                FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!--  MAIN AREA  -->
        <Border
            x:Name="brdrMain"
            Margin="10,60,10,10"
            Background="SteelBlue">
            <Border.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10" />
                </Style>
            </Border.Resources>

            <!--  Two-column layout: left = search, right = details  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  LEFT COLUMN  -->
                <Border
                    Grid.Column="0"
                    Margin="12,12,4,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="6,0,0,6">
                    <StackPanel x:Name="spnlSearch" Orientation="Vertical">
                        <StackPanel
                            x:Name="spnlSearchOptions"
                            Grid.Column="0"
                            Background="White"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnSearchToggle"
                                Width="200"
                                Height="42"
                                Margin="10,10,0,8"
                                HorizontalAlignment="left"
                                Click="btnSearchToggle_Click"
                                Content="Patient Search"
                                FontSize="18"
                                FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <StackPanel x:Name="spnlSearchByNameOrId" Orientation="Vertical">
                                <RadioButton
                                    x:Name="rbtnByName"
                                    Width="116"
                                    Margin="5,12,0,0"
                                    VerticalContentAlignment="Center"
                                    Checked="rbtnSearch_Checked"
                                    Content="By name"
                                    FontSize="14" />
                                <RadioButton
                                    x:Name="rbtnById"
                                    Width="116"
                                    Margin="5,5,0,0"
                                    VerticalContentAlignment="Center"
                                    Checked="rbtnSearch_Checked"
                                    Content="By ID"
                                    FontSize="14" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel
                            x:Name="spnlSearchBar"
                            Margin="0,0,0,6"
                            Orientation="Horizontal">
                            <TextBox
                                x:Name="txbxSearch"
                                Width="260"
                                Height="32"
                                Margin="10,0,8,0"
                                Padding="10,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="16"
                                TextChanged="txbxSearch_TextChanged">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Button
                                x:Name="btnGoSearch"
                                Width="32"
                                Height="32"
                                Content="&gt;">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5" />
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                        <ListBox
                            x:Name="lstbxSearchResults"
                            Height="450"
                            SelectionChanged="lstbxSearchResults_SelectionChanged">
                            <ListBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="7" />
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </StackPanel>
                </Border>
                <!--  Right: Details panel  -->
                <Border
                    x:Name="brdrRightPanel"
                    Grid.Column="1"
                    Margin="4,12,12,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="0,6,6,0">
                    <StackPanel x:Name="spnlDetailsMain">
                        <!--
                            Patient Details Section
                            This is what should be visible/collapsed when showing/hiding patient details.
                        -->
                        <StackPanel
                            x:Name="spnlPatientDetails"
                            Height="65"
                            Margin="0"
                            Background="White"
                            Orientation="Horizontal">
                            <StackPanel x:Name="spnlPatientNameAndId" Orientation="Vertical">
                                <Label
                                    x:Name="lblPatientHeader"
                                    Width="100"
                                    Height="64"
                                    Margin="0,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Black"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    Content="PATIENT"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="White">
                                    <Label.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5,0,0,5" />
                                        </Style>
                                    </Label.Resources>
                                </Label>

                            </StackPanel>
                            <StackPanel x:Name="spnlPatientHeaderAndIdKey" Orientation="vertical">


                                <!--  Patient Name  -->


                                <Label
                                    x:Name="lblPatientNameValue"
                                    Width="250"
                                    Height="32"
                                    Margin="0,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    BorderBrush="Black"
                                    BorderThickness="1,1,1,0"
                                    Content="----------------------------------"
                                    FontSize="16"
                                    FontWeight="SemiBold">
                                    <Label.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,5,0,0" />
                                        </Style>
                                    </Label.Resources>
                                </Label>
                                <Label
                                    x:Name="lblPatientIdValue"
                                    Width="250"
                                    Height="32"
                                    Margin="0,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1,0,1,1"
                                    Content="---------------------------------------"
                                    FontSize="14"
                                    FontWeight="Regular"
                                    Foreground="Black">
                                    <Label.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,0,5,0" />
                                        </Style>
                                    </Label.Resources>
                                </Label>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <StackPanel x:Name="spnlPatientPhone" Orientation="Horizontal">
                                    <Label
                                        x:Name="lblPatientPhoneKey"
                                        Width="60"
                                        Height="30"
                                        Margin="5,0,0,4"
                                        HorizontalContentAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        Background="Black"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        Content="Phone"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5,0,0,5" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <Label
                                        x:Name="lblPatientPhoneValue"
                                        Width="325"
                                        Height="30"
                                        Margin="0,0,0,4"
                                        Padding="0,0,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="Black"
                                        BorderThickness="1,1,0,1"
                                        Content="------------------------------------------------"
                                        FontSize="16"
                                        FontWeight="SemiBold">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,0" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <Button
                                        x:Name="btnPhoneDetails"
                                        Width="32"
                                        Height="30"
                                        Margin="0,0,0,4">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,5,5,0" />
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                                <StackPanel x:Name="spnlPatientEmail" Orientation="Horizontal">
                                    <Label
                                        x:Name="lblPatientEmailKey"
                                        Width="60"
                                        Height="30"
                                        Margin="5,0,0,0"
                                        HorizontalContentAlignment="Right"
                                        VerticalContentAlignment="Center"
                                        Background="Black"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        Content="Email"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5,0,0,5" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <Label
                                        x:Name="lblPatientEmailValue"
                                        Width="325"
                                        Height="30"
                                        Margin="0,0,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="Black"
                                        BorderThickness="1,1,0,1"
                                        Content="----------------------------------------------------------------"
                                        FontSize="12"
                                        FontWeight="Regular">
                                        <Label.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,0,0,0" />
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                    <Button
                                        x:Name="btnEmailDetails"
                                        Width="32"
                                        Height="30"
                                        Margin="0,0,0,0">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="0,5,5,0" />
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!--  Patient Meetings Section  -->
                        <StackPanel
                            x:Name="spnlPatientMeetings"
                            Margin="0,10,0,0">
                            <StackPanel
                                x:Name="spnlMeetingsHeader"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    x:Name="txtMeetingsTotal"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Meetings" />
                                <TextBlock
                                    FontSize="16"
                                    Text=": " />
                                <TextBlock
                                    x:Name="txtMeetingsCompleted"
                                    FontSize="16"
                                    Foreground="Green"
                                    Text="0 Completed" />
                                <TextBlock
                                    FontSize="16"
                                    Text=" / " />
                                <TextBlock
                                    x:Name="txtMeetingsInProgress"
                                    FontSize="16"
                                    Foreground="Orange"
                                    Text="0 In-Progress" />
                                <TextBlock
                                    FontSize="16"
                                    Text=" / " />
                                <TextBlock
                                    x:Name="txtMeetingsExpired"
                                    FontSize="16"
                                    Foreground="Red"
                                    Text="0 Expired" />
                                <TextBlock
                                    FontSize="16"
                                    Text=" / " />
                                <TextBlock
                                    x:Name="txtMeetingsCancelled"
                                    FontSize="16"
                                    Foreground="Black"
                                    Text="0 Cancelled" />
                                <TextBlock
                                    FontSize="16"
                                    Text=" / " />
                                <TextBlock
                                    x:Name="txtMeetingsScheduled"
                                    FontSize="16"
                                    Foreground="Gray"
                                    Text="0 Scheduled" />
                            </StackPanel>
                            <DataGrid
                                x:Name="dgPatientMeetings"
                                MaxHeight="120"
                                Height="120"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                CanUserResizeRows="False"
                                CanUserSortColumns="True"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                SelectionMode="Single"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <!--  Style for meeting rows  -->
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <!--  Cancelled meetings: light gray text  -->
                                            <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                                                <Setter Property="Foreground" Value="LightGray" />
                                            </DataTrigger>
                                            <!--  Completed meetings: bold text  -->
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <!--  Style for Meeting ID cells with errors  -->
                                    <Style x:Key="MeetingIdCellStyle" TargetType="DataGridCell">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                                <Setter Property="Background" Value="LightSalmon" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding MeetingId}"
                                        CellStyle="{StaticResource MeetingIdCellStyle}"
                                        Header="ID" />
                                    <DataGridTextColumn
                                        Width="140"
                                        Binding="{Binding Start}"
                                        Header="Scheduled Start" />
                                    <DataGridTextColumn
                                        Width="140"
                                        Binding="{Binding Arrived}"
                                        Header="Patient Arrived" />
                                    <DataGridTextColumn
                                        Width="140"
                                        Binding="{Binding Dropped}"
                                        Header="Patient Dropped" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding Duration}"
                                        Header="Patient Duration" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Status}"
                                        Header="Status" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                        <StackPanel
                            x:Name="spnlMeetingAdditionalDetails" Orientation="Vertical"
                            Margin="0,10,0,0">
                            <TextBlock
                                x:Name="txtblkMeetingDetailsHeader"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="-----" />
                            <Label
                                x:Name="lblPatientDetail"
                                
                                >
                                <Label.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3" />
                                    </Style>
                                </Label.Resources>
                            </Label>
                            
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
