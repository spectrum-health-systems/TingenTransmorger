<Window x:Class="TingenTransmorger.Database.DatabaseRebuildWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Rebuild" 
        Height="300" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" 
                   Text="Rebuilding Database" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>
        
        <TextBlock Grid.Row="1" 
                   x:Name="txtCurrentTask" 
                   Text="Initializing..." 
                   FontSize="14" 
                   Margin="0,0,0,10"/>
        
        <ProgressBar Grid.Row="2" 
                     x:Name="progressBar" 
                     Height="30" 
                     Minimum="0" 
                     Maximum="100" 
                     Value="0"/>
        
        <TextBlock Grid.Row="3" 
                   x:Name="txtStatus" 
                   Text="Starting..." 
                   FontSize="12" 
                   Foreground="Gray" 
                   Margin="0,10,0,0"/>
        
        <Button Grid.Row="4" 
                x:Name="btnClose" 
                Content="Close" 
                Width="100" 
                Height="30" 
                HorizontalAlignment="Center" 
                Margin="0,20,0,0" 
                Visibility="Collapsed"
                Click="btnClose_Click"/>
    </Grid>
</Window>
