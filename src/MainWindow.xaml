<Window
    x:Class="TingenTransmorger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TingenTransmorger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tingen Transmorger"
    Width="1200"
    Height="700"
    ResizeMode="NoResize"
    mc:Ignorable="d">
    <Grid>
        <!--  TOP BAR  -->
        <StackPanel x:Name="spnlTop" Orientation="Horizontal">
            <TextBlock
                x:Name="txblTingenTransmorgerTitle"
                Margin="20,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="28"
                FontWeight="Bold"
                Text="Tingen Transmorger" />
            <Button
                x:Name="btnSettings"
                Width="32"
                Height="32"
                Margin="310,15,20,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Content="S"
                FontSize="16"
                FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!--  MAIN AREA  -->
        <Border
            x:Name="brdrMain"
            Margin="10,60,10,10"
            Background="SteelBlue">
            <Border.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10" />
                </Style>
            </Border.Resources>

            <!--  Two-column layout: left = search, right = details  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  LEFT COLUMN  -->
                <Border
                    Grid.Column="0"
                    Margin="12,12,4,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="6,0,0,6">
                    <StackPanel x:Name="spnlSearch" Orientation="Vertical">
                        <StackPanel
                            x:Name="spnlSearchOptions"
                            Grid.Column="0"
                            Background="White"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnSearchToggle"
                                Width="200"
                                Height="42"
                                Margin="10,10,0,8"
                                HorizontalAlignment="left"
                                Click="btnSearchToggle_Click"
                                Content="Patient Search"
                                FontSize="18"
                                FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <StackPanel x:Name="spnlSearchByNameOrId" Orientation="Vertical">
                                <RadioButton
                                    x:Name="rbtnByName"
                                    Width="116"
                                    Margin="5,12,0,0"
                                    VerticalContentAlignment="Center"
                                    Content="By name"
                                    FontSize="14" />
                                <RadioButton
                                    x:Name="rbtnById"
                                    Width="116"
                                    Margin="5,5,0,0"
                                    VerticalContentAlignment="Center"
                                    Content="By ID"
                                    FontSize="14" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel
                            x:Name="spnlSearchBar"
                            Margin="0,0,0,6"
                            Orientation="Horizontal">
                            <TextBox
                                x:Name="txbxSearch"
                                Width="260"
                                Height="32"
                                Margin="10,0,8,0">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="7" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Button
                                x:Name="btnGoSearch"
                                Width="32"
                                Height="32"
                                Content="&gt;">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5" />
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                        <ListBox x:Name="lstbxSearchResults" Height="450">
                            <ListBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="7" />
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </StackPanel>
                </Border>
                <!--  Right: Details panel  -->
                <Border
                    Grid.Column="1"
                    Margin="4,12,12,12"
                    Padding="8"
                    Background="White"
                    CornerRadius="0,6,6,0">
                    <ScrollViewer>
                        <StackPanel x:Name="spnlDetails">
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="Details" />
                            <TextBlock
                                x:Name="txtDetailsPlaceholder"
                                Text="Select a result on the left to view details."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
